{
	"hosting": {
		"public": "public",
		"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
		"rewrites": [
			{
				"source": "**",
				"destination": "/index.html",
				"function": "api"
			},
			{
				"source": "/",
				"function": "healthCheck"
			},
			{
				"source": "/enquiry-test",
				"function": "enquiryGet"
			},
			{
				"source": "/enquiry",
				"function": "enquiryPost"
			}
		]
	},
	"functions": [
		{
			"source": "functions",
			"codebase": "default",
			"ignore": [
				"node_modules",
				".git",
				"firebase-debug.log",
				"firebase-debug.*.log",
				"*.local"
			],
			"predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
		}
	]
}
