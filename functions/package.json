		"firebase-admin": "^13.7.0",
		"firebase-functions": "^7.2.2",
		"http-status-codes": "^2.3.0",
		"install": "^0.13.0",
		"nodemailer": "^8.0.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"firebase-functions-test": "^3.4.1",
		"typescript": "^6.0.2"
