{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "outDir": "lib",
    "rootDir": "src",
    "target": "esnext",
    "lib": [
      "esnext"
    ]
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}